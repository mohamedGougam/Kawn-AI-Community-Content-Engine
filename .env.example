# Database
DATABASE_URL=postgresql+asyncpg://kawn:kawn_secret@localhost:5432/kawn_content_engine
DATABASE_URL_SYNC=postgresql://kawn:kawn_secret@localhost:5432/kawn_content_engine

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=change-me-in-production-use-a-long-random-string
CORS_ORIGINS=http://localhost:3000,http://frontend:3000

# Scheduler
SCHEDULER_ENABLED=true
DEFAULT_POSTS_PER_DAY=5
SEED_SAMPLE_DATA=false

# AI Providers (optional - mock provider used when keys missing)
AI_DEFAULT_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# News APIs (optional)
NEWS_API_KEY=
SPORTS_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Docker
POSTGRES_USER=kawn
POSTGRES_PASSWORD=kawn_secret
POSTGRES_DB=kawn_content_engine
POSTGRES_HOST_PORT=5433
